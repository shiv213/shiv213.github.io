---
title: Author archive
layout: layouts/base.njk
section: blog
pagination:
  data: collections.authors
  size: 1
  alias: author
permalink: "authors/{{ author | slug }}/"
renderData:
  author: "{{ author }}"
  title: "Posts by {{ author }} — Shiv Trivedi"
  metaDescription: "An archive of all posts by: {{ author }}."
---
<header class="blog-head">
  <h1>{{ author }}.</h1>
  <div><div class="sub">All posts by {{ author }}.</div></div>
  <a href="{{ '/blog/' | url }}" class="rss">← all writing</a>
</header>

<section class="blog-list">
  {%- for post in collections.authors[author] | reverse -%}
  <a class="row" href="{{ post.page.url | url }}">
    <div class="d"><b>{{ post.date | readableDate }}</b></div>
    <div class="body">
      <div class="kicker">
        {%- if post.tags -%}
          {%- for t in post.tags -%}{%- if t != "post" -%}{{ t }}{% if not loop.last %} · {% endif %}{%- endif -%}{%- endfor -%}
        {%- endif -%}
      </div>
      <h3>{{ post.title }}</h3>
      <p>{{ post.summary or post.metaDescription }}</p>
    </div>
    <div class="r">read →</div>
  </a>
  {%- endfor -%}
</section>

---
layout: layouts/base.njk
section: post
---
<div class="post-crumb"><a href="{{ '/blog/' | url }}">← writing</a> &nbsp;/&nbsp; {{ title }}</div>

<header class="phead">
  <div class="kicker">
    <span class="dot"></span>
    {%- if tags -%}
      {%- for t in tags -%}{%- if t != "post" -%}{{ t }}{% if not loop.last %} · {% endif %}{%- endif -%}{%- endfor -%}
    {%- endif -%}
  </div>
  <h1>{{ title }}</h1>
  <div class="meta-row">
    <span><time datetime="{{ date | machineDate }}">{{ date | readableDate }}</time></span>
    <span>·</span>
    <span>by <a href="/authors/{{ author | slug }}/">{{ author }}</a></span>
  </div>
</header>

<article class="prose">
  {{ layoutContent | safe }}
</article>

<div class="post-end">— end —</div>

<section class="related">
  <h2>more writing</h2>
  <div class="rgrid">
    {%- for p in collections.post | reverse -%}
      {%- if p.url != page.url and loop.index <= 2 -%}
      <a href="{{ p.url | url }}">
        <div class="d">{{ p.date | readableDate }}</div>
        <h3>{{ p.data.title }}</h3>
      </a>
      {%- endif -%}
    {%- endfor -%}
    <a href="{{ '/blog/' | url }}">
      <div class="d">ALL POSTS</div>
      <h3>archive →</h3>
    </a>
  </div>
</section>

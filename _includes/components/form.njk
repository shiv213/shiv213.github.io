<form class="contact-form" name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
  <input type="hidden" name="form-name" value="contact">
  <p hidden><label>Don't fill this out if you're human: <input name="bot-field"></label></p>
  <div class="meta" style="margin-bottom:20px">or leave a note</div>
  <div>
    <label for="name">your name</label>
    <input type="text" name="name" id="name" autocomplete="name" placeholder="e.g. alex" required>
  </div>
  <div>
    <label for="email">reply-to</label>
    <input type="email" name="email" id="email" autocomplete="email" placeholder="email@something.com" required>
  </div>
  <div>
    <label for="message">your note</label>
    <textarea name="message" id="message" placeholder="say anything" rows="5" required></textarea>
  </div>
  <button class="btn" type="submit" name="submit">send ↗</button>
</form>

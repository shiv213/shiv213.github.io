---
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - nav
    - post
    - posts
permalink: /tags/{{ tag }}/
layout: layouts/base.njk
section: blog
renderData:
  title: "Tagged “{{ tag }}” — Shiv Trivedi"
  metaDescription: "All posts from the Blog tagged with “{{ tag }}”"
---
<header class="blog-head">
  <h1>{{ tag }}.</h1>
  <div><div class="sub">Posts tagged “{{ tag }}”. <a class="link" href="{{ '/blog/' | url }}">clear filter ↗</a></div></div>
  <a href="/feed.xml" class="rss">↘ subscribe · rss</a>
</header>

<section class="blog-list">
  {%- for post in collections[tag] | reverse -%}
  <a class="row" href="{{ post.url | url }}">
    <div class="d"><b>{{ post.date | readableDate }}</b></div>
    <div class="body">
      <div class="kicker">
        {%- if post.data.tags -%}
          {%- for t in post.data.tags -%}{%- if t != "post" -%}{{ t }}{% if not loop.last %} · {% endif %}{%- endif -%}{%- endfor -%}
        {%- endif -%}
      </div>
      <h3>{{ post.data.title }}</h3>
      <p>{{ post.data.summary or post.data.metaDescription }}</p>
    </div>
    <div class="r">read →</div>
  </a>
  {%- endfor -%}
</section>
